# 服务器端口
PORT=3000

# 数据库类型：mysql 或 sqlite
DB_TYPE=mysql

# MySQL 数据库配置（当 DB_TYPE=mysql 时使用）
# 安全建议：生产环境应创建专用数据库账号，不要使用 root
# 创建方法：参见 scripts/create-db-user.sql
DB_HOST=localhost
DB_PORT=3306
DB_USER=chronos_user
DB_PASSWORD=your_password_here
DB_NAME=chronos_eye

# JWT 密钥（必须 ≥16 位强随机字符串）
# 生成方法：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS 允许的来源（逗号分隔，默认小程序开发服务器端口 10080）
CORS_ORIGIN=http://localhost:10080

# HTTPS 配置
# 生产环境必须使用 HTTPS，可通过以下方式实现：
# 1. Nginx 反向代理（推荐）：Nginx 处理 SSL 证书，转发到 Node.js
# 2. 直接配置 Node.js HTTPS（需证书文件）：
#    在 index.js 中改用 https.createServer({ key, cert }, app)
# 3. 使用云服务商的负载均衡器（如阿里云 SLB）自动处理 HTTPS
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem

# 云开发配置（主题管理功能）
# 微信云开发环境 ID
WX_CLOUD_ENV=env-9gbp93eo58c28b9c
# 安全建议：在微信云开发控制台将 theme_config 集合权限改为：
#   - 读权限：所有用户（小程序可直接读取当前主题）
#   - 写权限：仅服务端（切换/上传主题必须走服务端 API）

# 日志配置
# FORCE_LOG=1 可在生产环境强制输出日志（默认生产环境抑制 console.log）
# FORCE_LOG=1

# 环境
NODE_ENV=development

# 天行数据 API Key（用于获取精确农历、节假日、星座数据）
# 注册地址：https://www.tianapi.com/
# 免费套餐：30 次/天
# 支持的接口：
#   - /wannianli/index - 万年历（农历数据）
#   - /jiejiari/index - 节假日（含调休）
#   - /jieqi/index - 节气
#   - /star/index - 星座运势
#   - /xingzuo/index - 星座配对
TIANAPI_KEY=your_tianapi_key_here
