# 服务器端口
PORT=3000

# 数据库类型：mysql 或 sqlite
DB_TYPE=mysql

# MySQL 数据库配置（当 DB_TYPE=mysql 时使用）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=chronos_eye

# JWT 密钥
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# 环境
NODE_ENV=development

# 天行数据 API Key（用于获取精确农历、节假日、星座数据）
# 注册地址：https://www.tianapi.com/
# 免费套餐：30 次/天
# 支持的接口：
#   - /wannianli/index - 万年历（农历数据）
#   - /jiejiari/index - 节假日（含调休）
#   - /jieqi/index - 节气
#   - /star/index - 星座运势
#   - /xingzuo/index - 星座配对
TIANAPI_KEY=your_tianapi_key_here
