.container {
  min-height: 100vh;
  background: #f8f5f0;
  padding-bottom: 40rpx;
}

/* 顶部导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #d94343 0%, #e05c5c 100%);
  padding: 20rpx 30rpx;
  padding-top: calc(var(--status-bar-height) + 10rpx);
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.nav-title {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.nav-share {
  position: absolute;
  right: 30rpx;
  font-size: 36rpx;
}

/* 日期区域 */
.date-section {
  background: linear-gradient(135deg, #d94343 0%, #e05c5c 100%);
  padding: 30rpx 30rpx 50rpx;
  text-align: center;
  padding-top: 140rpx;
}

.solar-date {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 30rpx;
}

.arrow {
  font-size: 20rpx;
}

.lunar-date {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.lunar-icon {
  font-size: 40rpx;
}

.lunar-main {
  font-size: 72rpx;
  color: #d94343;
  font-weight: bold;
  background: #fff;
  padding: 10rpx 60rpx;
  border-radius: 12rpx;
}

.ganzhi-info {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 宜忌卡片 */
.yiji-card {
  background: #fffdf5;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  border: 1rpx solid #f0e5d0;
}

.yiji-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.yiji-main {
  flex: 1;
}

.yi-row, .ji-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.yi-ji-label {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.yi-label {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
}

.ji-label {
  background: linear-gradient(135deg, #595959 0%, #3f3f3f 100%);
}

.yi-ji-tags {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  border: 1rpx solid #d9d9d9;
}

.yi-tag {
  color: #52c41a;
  border-color: #52c41a;
  background: rgba(82, 196, 26, 0.05);
}

.ji-tag {
  color: #595959;
  border-color: #d9d9d9;
  background: #fafafa;
}

/* 详细卡片 */
.detail-card {
  background: #fffdf5;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  border: 1rpx solid #f0e5d0;
}

.huangdi-era {
  font-size: 32rpx;
  color: #333;
  text-align: center;
  margin-bottom: 20rpx;
}

.divider-line {
  height: 2rpx;
  background: linear-gradient(to right, transparent, #d4b483, transparent);
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  border-bottom: 1rpx solid #f5f0e6;
  padding-bottom: 16rpx;
  margin-bottom: 16rpx;
}

.info-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
  margin-bottom: 0;
}

.info-row-4 {
  justify-content: space-between;
}

.info-row-4 .info-item {
  text-align: center;
  flex: 1;
  padding: 0 10rpx;
}

.info-row-4 .info-item:not(:last-child) {
  border-right: 1rpx solid #f5f0e6;
}

.info-row-3 {
  justify-content: space-between;
  align-items: center;
}

.info-row-3 .info-item {
  text-align: center;
}

.info-row-3 .info-item.small {
  flex: 1.5;
  padding: 10rpx;
}

.info-row-3 .center-luo {
  flex: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
}

.info-row-2 {
  justify-content: space-around;
}

.info-row-2 .info-item {
  text-align: center;
  flex: 1;
  padding: 0 10rpx;
}

.info-row-2 .info-item:not(:last-child) {
  border-right: 1rpx solid #f5f0e6;
}

.info-row-bottom {
  display: block;
}

.info-row-bottom .info-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f0e6;
}

.info-row-bottom .info-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.info-label {
  font-size: 28rpx;
  color: #d94343;
  margin-bottom: 8rpx;
}

.info-label-gold {
  font-size: 28rpx;
  color: #b8860b;
  margin-bottom: 8rpx;
}

.info-label-red {
  font-size: 28rpx;
  color: #d94343;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
}

.info-value.multi-line {
  line-height: 1.8;
}

/* 罗盘 */
.luopan {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffeee6 0%, #ffe0d6 100%);
  border: 4rpx solid #d94343;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.luopan-center {
  text-align: center;
}

.luo-text {
  display: block;
  font-size: 24rpx;
  color: #d94343;
  font-weight: bold;
}

.luo-sub {
  display: block;
  font-size: 20rpx;
  color: #d94343;
}

/* 天文台节气信息 */
.term-info {
  margin-top: 30rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 12rpx;
  padding: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.term-badge {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.term-icon {
  font-size: 32rpx;
}

.term-name {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

.term-next {
  text-align: right;
}

.term-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 4rpx;
}

.term-days {
  display: block;
  font-size: 28rpx;
  color: #ffd700;
  font-weight: bold;
}

/* 纳音五行区域 */
.info-section {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* 十二时辰卡片 */
.shichen-card {
  background: #fffdf5;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  border: 1rpx solid #f0e5d0;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f0e6;
}

.card-title {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
}

.card-subtitle {
  font-size: 24rpx;
  color: #999;
}

.shichen-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.shichen-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  background: #faf8f0;
  border-radius: 12rpx;
}

.shichen-main {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
  border: 2rpx solid #ddd;
}

.shichen-main.ji {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  border-color: #4caf50;
}

.shichen-main.xiong {
  background: linear-gradient(135deg, #ffebee 0%, #ffcdd2 100%);
  border-color: #f44336;
}

.shichen-main.ping {
  background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
  border-color: #ff9800;
}

.shichen-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.shichen-ganzhi {
  font-size: 18rpx;
  color: #666;
}

.shichen-time {
  font-size: 20rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.shichen-suit {
  font-size: 18rpx;
  color: #999;
  text-align: center;
}
