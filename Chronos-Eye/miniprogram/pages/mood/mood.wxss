.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 30rpx;
}

/* Tab 切换栏 */
.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  padding: 8rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx 0;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, #C67D58 0%, #E8A87C 100%);
}

.tab-item.active .tab-text {
  color: #fff;
}

.tab-icon {
  font-size: 32rpx;
}

.tab-text {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

/* 内容卡片 */
.content-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.card-icon {
  font-size: 80rpx;
  text-align: center;
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 8rpx;
}

.card-date {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-bottom: 32rpx;
}

.card-content {
  background: #FAFAFA;
  border-radius: 16rpx;
  padding: 32rpx;
  min-height: 200rpx;
  margin-bottom: 32rpx;
}

.card-content.rest-content {
  background: #F0F7FF;
  display: flex;
  align-items: center;
  justify-content: center;
}

.content-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
}

/* 底部复制按钮 */
.card-footer {
  display: flex;
  justify-content: center;
}

.copy-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: linear-gradient(135deg, #C67D58 0%, #E8A87C 100%);
  padding: 20rpx 48rpx;
  border-radius: 50rpx;
}

.copy-icon {
  font-size: 32rpx;
}

.copy-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}