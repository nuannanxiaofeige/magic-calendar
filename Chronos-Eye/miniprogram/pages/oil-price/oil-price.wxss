/* ==================== 容器 ==================== */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 16rpx 16rpx 40rpx;
}

/* ==================== 省份选择 ==================== */
.province-section {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  border: 2rpx solid #e8e8e8;
  margin-bottom: 16rpx;
}

.province-picker {
  padding: 28rpx 32rpx;
}

.province-info {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.province-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #667eea;
}

.province-hint {
  font-size: 24rpx;
  color: #999;
}

/* ==================== 油价列表 ==================== */
.price-list {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  overflow: hidden;
}

.price-item-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.price-item-row:last-child {
  border-bottom: none;
}

.price-item-row.hidden {
  display: none;
}

.price-item-row.up {
  background: #fff8f8;
}

.price-item-row.down {
  background: #f8fff8;
}

.price-label {
  font-size: 30rpx;
  color: #333;
}

.price-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.price-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.price-change {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.price-list .price-item-row.up .price-change {
  color: #ff4d4f !important;
  background: #fff1f0 !important;
}

.price-list .price-item-row.down .price-change {
  color: #52c41a !important;
  background: #f6ffed !important;
}

/* ==================== 通用区块卡片 ==================== */
.section-card {
  background: rgba(255, 255, 255, 0.98);
  margin: 16rpx;
  padding: 28rpx 32rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.12);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 26rpx;
  color: #667eea;
}

/* 国际油价横向滚动 */
.international-scroll {
  width: 100%;
  white-space: nowrap;
}

.international-list {
  display: inline-flex;
  gap: 20rpx;
}

.international-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, #667eea15 0%, #764ba215 100%);
  padding: 24rpx 32rpx;
  border-radius: 16rpx;
  gap: 12rpx;
  min-width: 200rpx;
}

.intl-name {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.intl-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.intl-change {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.intl-change.up {
  background: #fff1f0;
  color: #ff4d4f;
}

.intl-change.down {
  background: #f6ffed;
  color: #52c41a;
}

/* ==================== 调价窗口提示卡片 ==================== */
.tips-card {
  background: linear-gradient(135deg, #fff7e6 0%, #fff0e6 100%);
  border: 1rpx solid #ffd591;
  margin: 16rpx;
  padding: 24rpx 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.tips-icon {
  font-size: 40rpx;
}

.tips-content {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.tips-desc {
  font-size: 24rpx;
  color: #666;
}

/* ==================== 调价历史记录 ==================== */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.history-date {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.history-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.history-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.history-label {
  font-size: 24rpx;
  color: #999;
}

.history-value {
  font-size: 26rpx;
  font-weight: 500;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.history-value.up {
  background: #fff1f0;
  color: #ff4d4f;
}

.history-value.down {
  background: #f6ffed;
  color: #52c41a;
}

/* ==================== 底部说明 ==================== */
.footer-tips {
  background: rgba(255, 255, 255, 0.9);
  margin: 16rpx;
  padding: 24rpx 32rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.tip-line {
  font-size: 24rpx;
  color: #666;
  line-height: 1.8;
}

/* ==================== 加载更多 ==================== */
.loading-more {
  text-align: center;
  padding: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
}

/* ==================== 弹窗样式 ==================== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-height: 80vh;
  background: #fff;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  padding: 8rpx;
  line-height: 1;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx 32rpx;
}

/* 国际油价详情列表 */
.intl-detail-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.intl-detail-item {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  gap: 16rpx;
}

.detail-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  min-width: 150rpx;
}

.detail-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.detail-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #667eea;
}

.detail-price::before {
  content: '￥';
  font-size: 24rpx;
}

.detail-change {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.detail-change.up {
  background: #fff1f0;
  color: #ff4d4f;
}

.detail-change.down {
  background: #f6ffed;
  color: #52c41a;
}

.detail-ext {
  font-size: 24rpx;
  color: #999;
  width: 100%;
}

/* 调价历史详情列表 */
.history-detail-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-detail-item {
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.detail-date {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #e9ecef;
}

.detail-rows {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.row-label {
  font-size: 26rpx;
  color: #666;
}

.row-value {
  font-size: 26rpx;
  font-weight: 500;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.row-value.up {
  background: #fff1f0;
  color: #ff4d4f;
}

.row-value.down {
  background: #f6ffed;
  color: #52c41a;
}
