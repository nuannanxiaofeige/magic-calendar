/* 容器 */
.container {
  padding: 20rpx 30rpx 60rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
}

/* 顶部标题 */
.header-bar {
  text-align: center;
  padding: 30rpx 0;
  color: #fff;
}

.header-title {
  font-size: 44rpx;
  font-weight: bold;
  display: block;
}

.header-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
  display: block;
  margin-top: 10rpx;
}

/* 模式切换 */
.mode-switch {
  display: flex;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 30rpx;
}

.mode-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  border-radius: 12rpx;
  color: #fff;
}

.mode-item.active {
  background: #fff;
  color: #667eea;
}

.mode-icon {
  font-size: 36rpx;
  margin-bottom: 6rpx;
}

.mode-text {
  font-size: 24rpx;
}

/* 配对区域 */
.match-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

/* 星座选择器 */
.sign-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.selector-label {
  font-size: 28rpx;
  color: #666;
}

.selector-value {
  display: flex;
  align-items: center;
}

.sign-symbol {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.sign-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.arrow {
  font-size: 32rpx;
  color: #999;
}

/* VS 分割线 */
.vs-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  margin: 10rpx 0;
}

.vs-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #667eea;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 配对按钮 */
.match-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 44rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  margin-top: 10rpx;
}

.match-btn:active {
  opacity: 0.8;
}

/* 结果区域 */
.result-section {
  margin-bottom: 30rpx;
}

.result-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
}

.result-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

/* 评分 */
.result-grade {
  display: flex;
  justify-content: space-around;
  margin-bottom: 30rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%);
  border-radius: 16rpx;
  padding: 20rpx;
}

.grade-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.grade-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.grade-stars {
  font-size: 28rpx;
  letter-spacing: 2rpx;
}

/* 配对内容 */
.result-content {
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%);
  border-radius: 16rpx;
  padding: 24rpx;
}

.content-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  text-align: justify;
}

/* 列表区域 */
.list-section {
  margin-bottom: 30rpx;
}

.list-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  text-align: center;
  margin-bottom: 20rpx;
}

.match-list {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
}

.match-list-item {
  padding: 24rpx;
  border-bottom: 1rpx solid #eee;
}

.match-list-item:last-child {
  border-bottom: none;
}

.list-item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.list-item-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.list-item-grade {
  font-size: 26rpx;
  color: #667eea;
}

.list-item-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 选择器弹窗 */
.selector-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: none;
  align-items: flex-end;
  z-index: 1000;
}

.selector-modal.show {
  display: flex;
}

.selector-content {
  width: 100%;
  background: #fff;
  border-radius: 30rpx 30rpx 0 0;
  padding: 30rpx;
  max-height: 70vh;
  overflow-y: auto;
}

.selector-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 24rpx;
}

.selector-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.selector-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%);
  border-radius: 16rpx;
}

.selector-symbol {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.selector-name {
  font-size: 24rpx;
  color: #333;
}
