/* 容器 */
.container {
  padding: 20rpx;
  background: transparent;
  min-height: 100vh;
  position: relative;
  z-index: 1;
}

/* 头部 */
.header {
  background: linear-gradient(135deg, #FDFBF7 0%, #F5F0E8 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.month-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
}

.arrow-btn {
  padding: 10rpx 20rpx;
  color: #fff;
}

.arrow {
  font-size: 32rpx;
}

.month-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin: 0 30rpx;
}

.lunar-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 星期标题 */
.weekdays {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.weekday {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #666;
}

.weekday:first-child,
.weekday:last-child {
  color: #e74c3c;
}

/* 日历网格 */
.calendar {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.day-cell {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: #f8f9fa;
  position: relative;
}

.day-cell.today {
  background: linear-gradient(135deg, #FDFBF7 0%, #F5F0E8 100%);
}

.day-cell.today .day-number,
.day-cell.today .day-lunar {
  color: #fff;
}

.day-cell.selected {
  background: rgba(102, 126, 234, 0.2);
  border: 2rpx solid #C67D58;
}

.day-cell.rest-day {
  background: #fff5f5;
}

.day-cell.rest-day .day-number {
  color: #e74c3c;
}

/* 法定节假日样式 */
.day-cell.official {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  box-shadow: 0 2rpx 8rpx rgba(238, 90, 90, 0.3);
}

.day-cell.official .day-number,
.day-cell.official .day-text {
  color: #fff;
}

.day-number {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}

.day-text {
  font-size: 20rpx;
  color: #999;
}

.day-text.festival {
  color: #27ae60;
}

.day-text.term {
  color: #e74c3c;
}

.day-text.lunar {
  color: #999;
}

/* 下月日期置灰 - 农历节日正常显示 */
.day-cell.next-month {
  background: #f0f0f0;
}

.day-cell.next-month .day-number {
  color: #bbb;
}

.day-cell.next-month .day-text.lunar {
  color: #bbb;
}

.day-cell.next-month .day-text.term {
  color: #d48e8e;
}

.day-cell.next-month .day-text.festival {
  color: #7cb37c;
}

/* 上月日期置灰 - 农历节日正常显示 */
.day-cell.prev-month {
  background: #f0f0f0;
}

.day-cell.prev-month .day-number {
  color: #bbb;
}

.day-cell.prev-month .day-text.lunar {
  color: #bbb;
}

.day-cell.prev-month .day-text.term {
  color: #d48e8e;
}

.day-cell.prev-month .day-text.festival {
  color: #7cb37c;
}

.day-mark {
  position: absolute;
  bottom: 8rpx;
}

.mark-dot {
  width: 8rpx;
  height: 8rpx;
  background: #C67D58;
  border-radius: 50%;
}

/* 选中日期详情 */
.selected-date-info {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.info-header {
  text-align: center;
  margin-bottom: 30rpx;
}

.info-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.info-lunar {
  display: block;
  font-size: 26rpx;
  color: #999;
}

.info-content {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.info-section {
  flex: 1;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
}

.section-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.section-value {
  display: block;
  font-size: 26rpx;
  line-height: 1.6;
}

.section-value.yi {
  color: #27ae60;
}

.section-value.ji {
  color: #e74c3c;
}

.info-events {
  border-top: 1rpx solid #eee;
  padding-top: 20rpx;
}

.events-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 15rpx;
}

.event-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 15rpx;
}

.event-year {
  font-size: 26rpx;
  color: #C67D58;
  font-weight: 500;
  margin-right: 15rpx;
  flex-shrink: 0;
}

.event-title {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  flex: 1;
}

/* 节假日 */
.festivals-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

.festival-item {
  display: flex;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.festival-item:last-child {
  border-bottom: none;
}

.festival-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.festival-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.festival-days {
  font-size: 24rpx;
  color: #999;
}
