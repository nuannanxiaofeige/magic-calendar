<!--pages/mine/mine.wxml-->
<!-- 全局背景 -->
<view class="global-bg" wx:if="{{globalBgUrl}}" style="background-image: url('{{globalBgUrl}}');"></view>

<view class="mine-container">
  <!-- 用户信息头部 -->
  <view class="user-header">
    <view class="avatar-wrapper">
      <image class="avatar" src="{{avatarUrl}}" mode="aspectFill" wx:if="{{avatarUrl}}"></image>
      <view class="avatar-placeholder" wx:else>👤</view>
    </view>
    <view class="user-info">
      <text class="nickname">{{nickname || '微信用户'}}</text>
      <text class="user-desc">时光记录者</text>
    </view>
    <!-- 主题切换按钮 -->
    <view class="theme-switch-btn" bindtap="showThemeSelector">
      <text class="theme-icon">🎨</text>
    </view>
  </view>

  <!-- 数据统计卡片 -->
  <view class="stats-card">
    <view class="stats-item">
      <text class="stats-number">{{stats.countdown}}个</text>
      <text class="stats-label">倒计时</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <text class="stats-number">{{stats.schedule}}个</text>
      <text class="stats-label">日程</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <text class="stats-number">{{stats.favorite}}个</text>
      <text class="stats-label">收藏</text>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="navigateTo" data-url="/pages/schedule/schedule">
      <view class="menu-left">
        <view class="menu-icon-wrapper menu-icon-schedule">
          <text class="menu-icon">📅</text>
        </view>
        <text class="menu-title">日程管理</text>
      </view>
      <view class="menu-arrow">
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="menu-item" bindtap="navigateTo" data-url="/pages/countdown/countdown">
      <view class="menu-left">
        <view class="menu-icon-wrapper menu-icon-countdown">
          <text class="menu-icon">⏳</text>
        </view>
        <text class="menu-title">倒计时</text>
      </view>
      <view class="menu-arrow">
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="menu-item" bindtap="navigateTo" data-url="/pages/history/history">
      <view class="menu-left">
        <view class="menu-icon-wrapper menu-icon-history">
          <text class="menu-icon">📜</text>
        </view>
        <text class="menu-title">历史上的今天</text>
      </view>
      <view class="menu-arrow">
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="menu-item" bindtap="navigateTo" data-url="/pages/holiday/holiday">
      <view class="menu-left">
        <view class="menu-icon-wrapper menu-icon-holiday">
          <text class="menu-icon">🎊</text>
        </view>
        <text class="menu-title">节日大全</text>
      </view>
      <view class="menu-arrow">
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 更多功能 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="navigateTo" data-url="/pages/constellation/constellation">
      <view class="menu-left">
        <view class="menu-icon-wrapper menu-icon-constellation">
          <text class="menu-icon">✨</text>
        </view>
        <text class="menu-title">星座运势</text>
      </view>
      <view class="menu-arrow">
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="menu-item" bindtap="navigateTo" data-url="/pages/match/match">
      <view class="menu-left">
        <view class="menu-icon-wrapper menu-icon-match">
          <text class="menu-icon">💕</text>
        </view>
        <text class="menu-title">星座配对</text>
      </view>
      <view class="menu-arrow">
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="menu-item" bindtap="navigateTo" data-url="/pages/oil-price/oil-price">
      <view class="menu-left">
        <view class="menu-icon-wrapper menu-icon-oil">
          <text class="menu-icon">⛽</text>
        </view>
        <text class="menu-title">油价查询</text>
      </view>
      <view class="menu-arrow">
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="menu-item" bindtap="navigateTo" data-url="/pages/calendar/calendar">
      <view class="menu-left">
        <view class="menu-icon-wrapper menu-icon-calendar">
          <text class="menu-icon">📆</text>
        </view>
        <text class="menu-title">万年历</text>
      </view>
      <view class="menu-arrow">
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="menu-item" bindtap="navigateTo" data-url="/pages/date-calc/date-calc">
      <view class="menu-left">
        <view class="menu-icon-wrapper menu-icon-calc">
          <text class="menu-icon">🔢</text>
        </view>
        <text class="menu-title">日期计算</text>
      </view>
      <view class="menu-arrow">
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="menu-item" bindtap="navigateTo" data-url="/pages/idiom-quiz/idiom-quiz">
      <view class="menu-left">
        <view class="menu-icon-wrapper menu-icon-idiom">
          <text class="menu-icon">📝</text>
        </view>
        <text class="menu-title">成语填词</text>
      </view>
      <view class="menu-arrow">
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 设置区域 -->
  <view class="menu-section">
    <!-- 主题切换入口 -->
    <view class="menu-item" bindtap="showThemeSelector">
      <view class="menu-left">
        <view class="menu-icon-wrapper" style="background: linear-gradient(135deg, #FDFBF7 0%, #F5F0E8 100%);">
          <text class="menu-icon">🎨</text>
        </view>
        <text class="menu-title">切换背景</text>
      </view>
      <view class="menu-arrow">
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="menu-item" bindtap="showFeedback">
      <view class="menu-left">
        <view class="menu-icon-wrapper menu-icon-feedback">
          <text class="menu-icon">💬</text>
        </view>
        <text class="menu-title">意见反馈</text>
      </view>
      <view class="menu-arrow">
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="menu-item" bindtap="showAbout">
      <view class="menu-left">
        <view class="menu-icon-wrapper menu-icon-about">
          <text class="menu-icon">ℹ️</text>
        </view>
        <text class="menu-title">关于我们</text>
      </view>
      <view class="menu-arrow">
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text class="version-text">Version 1.0.0</text>
  </view>
</view>
