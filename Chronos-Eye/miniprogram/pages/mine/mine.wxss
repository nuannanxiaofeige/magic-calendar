/*pages/mine/mine.wxss*/
.mine-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 用户信息头部 */
.user-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 80rpx 30rpx 60rpx;
  display: flex;
  align-items: center;
}

.avatar-wrapper {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #fff;
  padding: 4rpx;
  margin-right: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 60rpx;
}

.user-info {
  flex: 1;
}

.nickname {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.user-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 统计卡片 */
.stats-card {
  background: #fff;
  margin: -40rpx 30rpx 30rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-number {
  font-size: 40rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  color: #999;
}

.stats-divider {
  width: 1rpx;
  height: 60rpx;
  background: #eee;
}

/* 菜单区域 */
.menu-section {
  margin-top: 30rpx;
  background: #fff;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.menu-icon {
  font-size: 36rpx;
}

.menu-icon-schedule {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.menu-icon-countdown {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.menu-icon-history {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.menu-icon-holiday {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
}

.menu-icon-constellation {
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
}

.menu-icon-match {
  background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%);
}

.menu-icon-oil {
  background: linear-gradient(135deg, #f6d365 0%, #fda085 100%);
}

.menu-icon-calendar {
  background: linear-gradient(135deg, #84fab0 0%, #8fd3f4 100%);
}

.menu-icon-calc {
  background: linear-gradient(135deg, #cfd9df 0%, #e2ebf0 100%);
}

.menu-icon-idiom {
  background: linear-gradient(135deg, #d299c2 0%, #fef9d7 100%);
}

.menu-icon-feedback {
  background: linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%);
}

.menu-icon-about {
  background: linear-gradient(135deg, #cd9cf2 0%, #f6f3ff 100%);
}

.menu-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.menu-arrow {
  display: flex;
  align-items: center;
}

.arrow {
  font-size: 40rpx;
  color: #ccc;
  line-height: 1;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding-top: 60rpx;
}

.version-text {
  font-size: 24rpx;
  color: #999;
}
