/* 整体背景 - 动态季节背景 */
.container {
  min-height: 100vh;
  background: transparent;
  position: relative;
  z-index: 1;
  padding: 20rpx 30rpx;
  position: relative;
  z-index: 1;
}

/* 顶部日历卡片 - 半透明 */
.calendar-card {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(10px);
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 32rpx;
}

/* 卡片头部 - 星期和时间 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.time-icon {
  font-size: 28rpx;
}

.weekday {
  font-size: 26rpx;
  color: #666;
}

.header-center {
  font-size: 26rpx;
  color: #C62828;
  font-weight: 500;
}

.header-right {
  font-size: 24rpx;
  color: #999;
}

/* 大日期 */
.card-main {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.big-day {
  font-size: 140rpx;
  font-weight: bold;
  color: #C62828;
  line-height: 1;
  margin-bottom: 8rpx;
}

.year {
  font-size: 26rpx;
  color: #666;
}

/* 农历和干支 */
.card-lunar {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  border-top: 1rpx dashed #E8E8E8;
  margin-top: 10rpx;
}

.lunar-text {
  font-size: 26rpx;
  color: #997B5D;
  margin-bottom: 8rpx;
}

.ganzhi-text {
  font-size: 22rpx;
  color: #C4A882;
}

/* 宜忌区域 */
.yi-ji-section {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F5F5F5;
}

.yi-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.yi-row:last-child {
  margin-bottom: 0;
}

.yi-square {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  flex-shrink: 0;
}

.yi {
  background: #C62828;
}

.ji {
  background: #3D4852;
}

.yi-content {
  flex: 1;
  margin-left: 20rpx;
  padding: 16rpx 20rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333;
}

/* 节日区域 */
.festival-section {
  margin-bottom: 32rpx;
}

.section-title-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.title-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.title-icon {
  width: 6rpx;
  height: 28rpx;
  background: #C67D58;
  border-radius: 3rpx;
}

.title-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.more-link {
  font-size: 24rpx;
  color: #C67D58;
}

/* 节日卡片 */
.festival-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.festival-left {
  flex-shrink: 0;
}

.festival-icon-bg {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.festival-emoji {
  font-size: 48rpx;
}

.festival-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.festival-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.festival-date {
  font-size: 24rpx;
  color: #999;
}

.vacation-tag {
  display: inline-block;
  background: #FFF0F0;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-top: 8rpx;
}

.vacation-text {
  font-size: 20rpx;
  color: #C62828;
}

.festival-countdown {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #FFF5D0;
  padding: 12rpx 20rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.countdown-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #C67D58;
  line-height: 1;
}

.countdown-unit {
  font-size: 20rpx;
  color: #C67D58;
  margin-top: 4rpx;
}

/* 实用工具区域 */
.tools-section {
  margin-bottom: 20rpx;
}

/* 每日心情轮播 */
.mood-section {
  margin-bottom: 32rpx;
}

.mood-swiper {
  height: 180rpx;
}

.mood-swiper-item {
  display: flex;
  align-items: center;
  width: 100%;
  box-sizing: border-box;
}

.mood-card {
  border-radius: 24rpx;
  padding: 24rpx;
  height: 200rpx;
  width: 100%;
  background-size: cover;
  background-position: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
  justify-content: center;
  box-sizing: border-box;
}

.mood-card-tiangou {
  background: linear-gradient(135deg, #FFB6C1 0%, #FF69B4 100%);
}

.mood-card-worker {
  background: linear-gradient(135deg, #87CEEB 0%, #4682B4 100%);
}

.mood-card-default {
  background: linear-gradient(135deg, #DDA0DD 0%, #9370DB 100%);
}

.mood-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.mood-icon {
  font-size: 36rpx;
}

.mood-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #fff;
}

.mood-content {
  background: rgba(255, 255, 255, 0.25);
  border-radius: 12rpx;
  padding: 16rpx;
  flex: 1;
  display: flex;
  align-items: center;
}

.mood-text {
  font-size: 26rpx;
  color: #fff;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.tools-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.tool-item {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.tool-item:active {
  transform: scale(0.96);
}

.tool-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

.tool-text {
  font-size: 24rpx;
  color: #333;
  text-align: center;
}
