.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding-bottom: 40rpx;
}

/* 头部卡片 - 更紧凑 */
.header-card {
  background: rgba(255, 255, 255, 0.98);
  margin: 16rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.12);
  backdrop-filter: blur(10px);
  cursor: pointer;
}

.header-card:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 日期区域 - 字体加大 */
.date-section {
  text-align: center;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.solar-date {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.05);
}

.lunar-date {
  display: block;
  font-size: 28rpx;
  color: #667eea;
  font-weight: 500;
}

.ganzhi-date {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 黄历宜忌 - 横向布局 */
.almanac-row {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
}

.almanac-item {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 10rpx 14rpx;
  border-radius: 10rpx;
}

.almanac-yi {
  background: linear-gradient(135deg, #ffebee 0%, #ffcdd2 100%);
}

.almanac-ji {
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
}

.almanac-label {
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.almanac-yi .almanac-label {
  color: #c62828;
}

.almanac-ji .almanac-label {
  color: #1565c0;
}

.almanac-content {
  flex: 1;
  font-size: 24rpx;
  color: #555;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: break-all;
  line-height: 1.3;
  max-height: 60rpx;
}

/* 分隔线 */
.divider {
  height: 1rpx;
  background: linear-gradient(to right, transparent, rgba(102, 126, 234, 0.2), transparent);
  margin: 14rpx 0;
}

/* 今日节气/农历节日 - 并排布局 */
.today-info {
  display: flex;
  gap: 12rpx;
}

.today-item {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 14rpx 18rpx;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.today-item:active {
  transform: scale(0.98);
}

/* 节气样式 */
.term-item {
  background: linear-gradient(135deg, rgba(39, 174, 96, 0.1) 0%, rgba(46, 204, 113, 0.08) 100%);
  border: 1rpx solid rgba(39, 174, 96, 0.2);
}

/* 农历节日样式 */
.lunar-item {
  background: linear-gradient(135deg, rgba(230, 126, 34, 0.1) 0%, rgba(243, 156, 18, 0.08) 100%);
  border: 1rpx solid rgba(230, 126, 34, 0.2);
}

.today-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.today-content {
  flex: 1;
  overflow: hidden;
}

.today-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.3;
}

.today-subtitle {
  display: block;
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 信息行布局 - 备用（已废弃，保留以防兼容性问题） */
.info-row {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}

/* 最近节日区域 */
.next-festival-section {
  padding: 0 24rpx;
  margin-top: 16rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
  position: relative;
  padding-left: 14rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 24rpx;
  background: #fff;
  border-radius: 3rpx;
}

.section-more {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

/* 节日卡片 - 更紧凑 */
.festival-card {
  background: #fff;
  border-radius: 14rpx;
  padding: 20rpx 22rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.festival-card:active {
  transform: scale(0.98);
}

.festival-main {
  display: flex;
  align-items: center;
}

.festival-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
}

.festival-info {
  flex: 1;
}

.festival-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.festival-date {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.festival-countdown {
  text-align: center;
  min-width: 60rpx;
  padding: 10rpx 12rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 10rpx;
}

.countdown-number {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1;
}

.countdown-label {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 2rpx;
}

.festival-footer {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f0f0f0;
}

.official-tag {
  display: inline-block;
  background: linear-gradient(135deg, #f5222d 0%, #ff4d4f 100%);
  color: #fff;
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.vacation-days {
  font-size: 20rpx;
  color: #999;
  background: #f8f9fa;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
}

/* 历史事件区域 */
.history-section {
  background: #fff;
  margin: 16rpx 24rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.history-section .section-title {
  color: #333;
  text-shadow: none;
}

.history-section .section-title::before {
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
}

.history-section .section-more {
  color: #667eea;
}

.history-list {
  margin-top: 16rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.history-item:last-child {
  border-bottom: none;
}

.history-item:active {
  background: #fafafa;
  margin: 0 -20rpx;
  padding-left: 20rpx;
  padding-right: 20rpx;
  border-radius: 8rpx;
}

.history-year {
  font-size: 28rpx;
  font-weight: bold;
  color: #667eea;
  margin-right: 16rpx;
  min-width: 100rpx;
}

.history-title {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  line-height: 1.4;
}

/* 快捷功能入口 - 一行 4 个 */
.quick-access {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  padding: 0 24rpx;
  margin-top: 16rpx;
}

/* 第二行快捷入口 - 居中显示，支持 2-3 个项目 */
.quick-access-row2 {
  margin-top: 12rpx;
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.quick-access-row2 .access-item {
  flex-shrink: 0;
  width: calc((100% - 24rpx) / 4);
}

.access-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 8rpx;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  transition: all 0.2s ease;
}

.access-item:active {
  transform: scale(0.96);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.06);
}

.access-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.access-text {
  font-size: 20rpx;
  color: #333;
  font-weight: 500;
}
