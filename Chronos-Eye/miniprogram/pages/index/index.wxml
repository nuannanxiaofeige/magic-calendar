<!-- 全局背景 -->
<global-bg src="{{globalBgUrl}}"></global-bg>

<view class="container">
  <!-- 顶部日历卡片 -->
  <view class="calendar-card" bindtap="goToCalendar">
    <view class="card-header">
      <view class="header-left">
        <text class="time-icon">🕐</text>
        <text class="weekday">{{weekday}}</text>
      </view>
      <text class="header-center">{{currentDate}}</text>
      <text class="header-right">{{currentTime}}</text>
    </view>

    <view class="card-main">
      <text class="big-day">{{day}}</text>
      <text class="year">{{year}}年</text>
    </view>

    <view class="card-lunar">
      <text class="lunar-text">农历{{lunarYear}}年{{lunarMonth}}月{{lunarDay}}</text>
      <text class="ganzhi-text">{{ganzhiYear}} {{ganzhiMonth}} {{ganzhiDay}}</text>
    </view>

    <!-- 宜忌 -->
    <view class="yi-ji-section">
      <view class="yi-row">
        <view class="yi-square yi">宜</view>
        <view class="yi-content">{{almanac.yi}}</view>
      </view>
      <view class="yi-row">
        <view class="yi-square ji">忌</view>
        <view class="yi-content">{{almanac.ji}}</view>
      </view>
    </view>
  </view>

  <!-- 最近节日 -->
  <view class="festival-section">
    <view class="section-title-bar">
      <view class="title-left">
        <view class="title-icon"></view>
        <text class="title-text">最近节日</text>
      </view>
      <text class="more-link" bindtap="goToHolidayList">更多 ></text>
    </view>

    <view class="festival-card" wx:if="{{festivals.length > 0}}" bindtap="goToDetail" data-id="{{festivals[0].id}}">
      <view class="festival-left">
        <view class="festival-icon-bg" style="background: {{festivals[0].style.gradient}}">
          <text class="festival-emoji">{{festivals[0].style.icon}}</text>
        </view>
      </view>
      <view class="festival-main">
        <text class="festival-name">{{festivals[0].name}}</text>
        <text class="festival-date">{{festivals[0].date_display}}</text>
        <view class="vacation-tag" wx:if="{{festivals[0].vacation_dates}}">
          <text class="vacation-text">假期：{{festivals[0].vacation_dates_formatted}}</text>
        </view>
      </view>
      <view class="festival-countdown" wx:if="{{festivals[0].days_left >= 0}}">
        <text class="countdown-num">{{festivals[0].days_left}}</text>
        <text class="countdown-unit">天</text>
      </view>
    </view>
  </view>

  <!-- 每日心情轮播 -->
  <view class="mood-section" wx:if="{{moodSwiper.length > 0}}">
    <view class="section-title-bar">
      <view class="title-left">
        <view class="title-icon"></view>
        <text class="title-text">每日心情</text>
      </view>
    </view>

    <swiper class="mood-swiper" indicator-dots="{{moodSwiper.length > 1}}" autoplay circular interval="4000" indicator-active-color="#C67D58" bindchange="onMoodSwiperChange">
      <swiper-item wx:for="{{moodSwiper}}" wx:key="index" class="mood-swiper-item">
        <view class="mood-card mood-card-{{item.type}}">
                    <view class="mood-content">
            <text class="mood-text">{{item.content}}</text>
          </view>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 实用工具 -->
  <view class="tools-section">
    <view class="section-title-bar">
      <view class="title-left">
        <view class="title-icon"></view>
        <text class="title-text">实用工具</text>
      </view>
    </view>

    <view class="tools-grid">
      <view class="tool-item" bindtap="goToHistory">
        <view class="tool-icon" style="background: #FFE5B8">📜</view>
        <text class="tool-text">历史上的今天</text>
      </view>
      <view class="tool-item" bindtap="goToHolidayList">
        <view class="tool-icon" style="background: #FFF3E0">🎊</view>
        <text class="tool-text">节日大全</text>
      </view>
      <view class="tool-item" bindtap="goToConstellation">
        <view class="tool-icon" style="background: #FFF9C4">✨</view>
        <text class="tool-text">星座运势</text>
      </view>
      <view class="tool-item" bindtap="goToOilPrice">
        <view class="tool-icon" style="background: #FFCDD2">⛽</view>
        <text class="tool-text">油价查询</text>
      </view>
      <view class="tool-item" bindtap="goToMatch">
        <view class="tool-icon" style="background: #F8BBD0">💕</view>
        <text class="tool-text">星座配对</text>
      </view>
      <view class="tool-item" bindtap="goToDateCalc">
        <view class="tool-icon" style="background: #E3F2FD">📅</view>
        <text class="tool-text">日期计算</text>
      </view>
      <view class="tool-item" bindtap="goToIdiomQuiz">
        <view class="tool-icon" style="background: #F3E5F5">📝</view>
        <text class="tool-text">成语查询</text>
      </view>
    </view>
  </view>

  <!-- 占位，避免被底部遮挡 -->
  <view style="height: 100rpx;"></view>
</view>
