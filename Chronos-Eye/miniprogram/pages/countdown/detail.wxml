<global-bg src="{{globalBgUrl}}"></global-bg>

<view class="detail-container" style="background: {{gradient}}" wx:if="{{!loading && holiday}}">
  <!-- 头部区域 -->
  <view class="detail-header">
    <view class="detail-header-content">
      <text class="detail-holiday-name">{{holiday.name}}</text>
      <view class="detail-countdown">
        <text class="detail-days-number">{{holiday.days_left}}</text>
        <text class="detail-days-unit">天</text>
      </view>
      <text class="detail-countdown-label">
        <block wx:if="{{holiday.days_left === 0}}">就是今天！</block>
        <block wx:else>距离{{holiday.name}}还有</block>
      </text>
    </view>
  </view>

  <!-- 详细信息区域 -->
  <view class="detail-content">
    <!-- 基本信息卡片 -->
    <view class="detail-card">
      <text class="detail-card-title">基本信息</text>

      <view class="detail-row">
        <text class="detail-row-label">📅 节日日期</text>
        <text class="detail-row-value">{{duration_text}}</text>
      </view>

      <view class="detail-row">
        <text class="detail-row-label">🏷️ 节日类型</text>
        <text class="detail-row-value">{{typeText}}</text>
      </view>

      <block wx:if="{{vacation_dates.length > 0}}">
        <view class="detail-row">
          <text class="detail-row-label">⏱️ 假期天数</text>
          <text class="detail-row-value">共 {{vacation_dates.length}} 天</text>
        </view>
      </block>

      <block wx:if="{{holiday.is_official === 1}}">
        <view class="detail-row">
          <text class="detail-row-label">✨ 法定节假日</text>
          <text class="detail-row-value">是</text>
        </view>
      </block>
    </view>

    <!-- 假期安排卡片 -->
    <block wx:if="{{vacation_dates.length > 0}}">
      <view class="detail-card">
        <text class="detail-card-title">假期安排</text>

        <view class="detail-row detail-full">
          <text class="detail-row-label">📆 放假时间</text>
          <text class="detail-row-value detail-text">{{duration_text}}</text>
        </view>

        <block wx:if="{{holiday.tip}}">
          <view class="detail-row detail-full">
            <text class="detail-row-label">💡 放假说明</text>
            <text class="detail-row-value detail-text">{{holiday.tip}}</text>
          </view>
        </block>

        <block wx:if="{{work_dates.length > 0}}">
          <view class="detail-row detail-full">
            <text class="detail-row-label">⚠️ 调休上班</text>
            <text class="detail-row-value detail-text">{{work_dates_text}}</text>
          </view>
        </block>

        <block wx:if="{{holiday.rest_tip}}">
          <view class="detail-row detail-full">
            <text class="detail-row-label">📝 请假建议</text>
            <text class="detail-row-value detail-text">{{holiday.rest_tip}}</text>
          </view>
        </block>
      </view>
    </block>

    <!-- 三倍工资信息 -->
    <block wx:if="{{wage_dates.length > 0}}">
      <view class="detail-card">
        <text class="detail-card-title">加班工资</text>
        <view class="detail-row detail-full">
          <text class="detail-row-label">💰 三倍工资日期</text>
          <text class="detail-row-value detail-text">{{wage_dates_text}}</text>
        </view>
      </view>
    </block>

    <!-- 节日文化卡片 -->
    <block wx:if="{{holiday.description || holiday.customs}}">
      <view class="detail-card">
        <text class="detail-card-title">节日文化</text>

        <block wx:if="{{holiday.description}}">
          <view class="detail-row detail-full">
            <text class="detail-row-label">📖 节日介绍</text>
            <text class="detail-row-value detail-text">{{holiday.description}}</text>
          </view>
        </block>

        <block wx:if="{{holiday.customs}}">
          <view class="detail-row detail-full">
            <text class="detail-row-label">🎊 传统习俗</text>
            <text class="detail-row-value detail-text">{{holiday.customs}}</text>
          </view>
        </block>
      </view>
    </block>

    <!-- 状态标签 -->
    <view class="detail-tags">
      <block wx:if="{{holiday.is_official === 1}}">
        <view class="detail-tag detail-tag-primary">法定节假日</view>
      </block>
      <block wx:if="{{holiday.is_rest === 1 && !holiday.is_work}}">
        <view class="detail-tag detail-tag-success">休息日</view>
      </block>
      <block wx:if="{{holiday.is_work === 1}}">
        <view class="detail-tag detail-tag-warning">调休上班</view>
      </block>
    </view>
  </view>

  <!-- 底部占位 -->
  <view class="detail-bottom-spacer" />
</view>

<!-- 加载中 -->
<view class="detail-loading" wx:if="{{loading}}">
  <text>加载中...</text>
</view>

<!-- 无数据 -->
<view class="detail-empty" wx:if="{{!loading && !holiday}}">
  <text>暂无数据</text>
</view>