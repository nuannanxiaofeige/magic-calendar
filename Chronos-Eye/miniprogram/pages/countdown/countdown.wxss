.container {
  min-height: 100vh;
  background: transparent;
  position: relative;
  z-index: 1;
  padding-bottom: 120rpx;
}

.header {
  background: linear-gradient(135deg, #FDFBF7 0%, #F5F0E8 100%);
  padding: 60rpx 30rpx 80rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.countdown-list {
  padding: 30rpx;
  margin-top: -40rpx;
}

.countdown-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.card-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.holiday-name {
  font-size: 32rpx;
  font-weight: bold;
}

.holiday-date {
  font-size: 24rpx;
  color: #999;
}

.card-body {
  display: flex;
  align-items: baseline;
  justify-content: center;
  padding: 30rpx 0;
  background: linear-gradient(135deg, #FDFBF7 0%, #F5F0E8 100%);
  border-radius: 12rpx;
}

.days-count {
  font-size: 72rpx;
  font-weight: bold;
  color: #fff;
}

.days-label {
  font-size: 32rpx;
  color: #fff;
  margin-left: 10rpx;
}

.card-footer {
  text-align: center;
  margin-top: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-text {
  font-size: 24rpx;
  color: #666;
}

.delete-btn {
  font-size: 24rpx;
  color: #e74c3c;
  padding: 8rpx 16rpx;
  background: #fee;
  border-radius: 20rpx;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.empty-subtext {
  display: block;
  font-size: 24rpx;
  color: #bbb;
}

.add-button {
  position: fixed;
  bottom: 80rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #FDFBF7 0%, #F5F0E8 100%);
  color: #fff;
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  box-shadow: 0 10rpx 30rpx rgba(102, 126, 234, 0.4);
}
