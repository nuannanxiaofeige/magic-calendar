.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding: 20rpx;
}

/* 选项卡 */
.tabs {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 8rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-weight: bold;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  text-align: center;
}

/* 表单行 */
.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-row:last-of-type {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #666;
  width: 140rpx;
}

.picker, .input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  text-align: right;
  padding: 10rpx 20rpx;
  background: #f8f9fa;
  border-radius: 8rpx;
}

.input {
  text-align: left;
}

/* 结果框 */
.result-box {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 24rpx 0;
  text-align: center;
}

.result-label {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 12rpx;
}

.result-number {
  display: block;
  font-size: 64rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1.2;
}

.result-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 12rpx;
}

/* 计算按钮 */
.calc-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: bold;
  margin-top: 20rpx;
}

.calc-btn:active {
  opacity: 0.9;
}

/* 快捷选择 */
.quick-select {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.quick-title {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.quick-list {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.quick-item {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 26rpx;
  transition: all 0.2s ease;
}

.quick-item:active {
  transform: scale(0.95);
}
